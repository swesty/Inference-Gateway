# ── Server ────────────────────────────────────────────────
# Port the gateway listens on (default: 8080)
PORT=8080

# ── vLLM Backend ──────────────────────────────────────────
# Disable TLS certificate verification for vLLM backends (default: true)
# VLLM_TLS_VERIFY=false

# Server profile label for metrics/logging (default: "default")
# VLLM_SERVER_PROFILE=default

# ── Engine Routing (optional, pick one) ───────────────────
# Explicit technique → URL mapping as JSON
# VLLM_BACKEND_MAP_JSON={"baseline":"http://localhost:8000","chunked_prefill":"http://localhost:8001"}

# Auto port-offset routing: baseline=+0, chunked_prefill=+1, speculative=+2, beam_search=+3
# VLLM_AUTO_ENGINE_ROUTING=true
