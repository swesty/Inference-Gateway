{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "templating": {
    "list": [
      {
        "name": "server_profile",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(requests_total, server_profile)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(requests_total{server_profile=~\"$server_profile\"}[1m])) by (technique, server_profile)",
          "legendFormat": "{{server_profile}} / {{technique}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(request_duration_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_duration_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(request_duration_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(requests_total{server_profile=~\"$server_profile\"}[1m])) by (technique, server_profile) - sum(rate(requests_total{server_profile=~\"$server_profile\"}[1m])) by (technique, server_profile)",
          "legendFormat": "errors (placeholder)",
          "refId": "A",
          "hide": true
        },
        {
          "expr": "sum(rate(requests_total{server_profile=~\"$server_profile\"}[5m])) by (technique, server_profile)",
          "legendFormat": "{{server_profile}} / {{technique}} total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "description": "Total request rate by technique. Error-specific counters require HTTP status label (future enhancement)."
    },
    {
      "title": "Token Rate (tok/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(prompt_tokens_total{server_profile=~\"$server_profile\"}[5m])) by (server_profile)",
          "legendFormat": "{{server_profile}} prompt tok/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(completion_tokens_total{server_profile=~\"$server_profile\"}[5m])) by (server_profile)",
          "legendFormat": "{{server_profile}} completion tok/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "axisCenteredZero": false
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(requests_total{server_profile=~\"$server_profile\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Prompt Tokens",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 16 },
      "targets": [
        {
          "expr": "sum(prompt_tokens_total{server_profile=~\"$server_profile\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Completion Tokens",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(completion_tokens_total{server_profile=~\"$server_profile\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Tokens/sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(completion_tokens_total{server_profile=~\"$server_profile\"}[5m])) / sum(rate(requests_total{server_profile=~\"$server_profile\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 1 },
        "overrides": []
      }
    },
    {
      "title": "Avg TTFT",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(time_to_first_token_seconds_sum{server_profile=~\"$server_profile\"}[5m])) / sum(rate(time_to_first_token_seconds_count{server_profile=~\"$server_profile\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "title": "Estimated GPU Cost",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 16 },
      "targets": [
        {
          "expr": "sum(estimated_gpu_cost_usd_total{server_profile=~\"$server_profile\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 4 },
        "overrides": []
      }
    },
    {
      "title": "Time to First Token (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(time_to_first_token_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(time_to_first_token_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Time per Output Token (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(time_per_output_token_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(time_per_output_token_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Completion Tokens/sec by Technique (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(completion_tokens_per_second_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(completion_tokens_per_second_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Inter-Chunk Delay (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(stream_inter_chunk_delay_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(stream_inter_chunk_delay_seconds_bucket{server_profile=~\"$server_profile\"}[5m])) by (le, technique, server_profile))",
          "legendFormat": "{{server_profile}} / {{technique}} p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Requests by Technique",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum(requests_total{server_profile=~\"$server_profile\"}) by (technique, server_profile)",
          "legendFormat": "{{server_profile}} / {{technique}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Estimated GPU Cost Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "sum(rate(estimated_gpu_cost_usd_total{server_profile=~\"$server_profile\"}[5m])) by (server_profile) * 3600",
          "legendFormat": "{{server_profile}} $/hr",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "decimals": 2
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["inference-gateway"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Inference Gateway Overview",
  "uid": "inference-gateway-overview"
}
